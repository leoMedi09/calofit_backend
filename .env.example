# ============================================================================
# CaloFit Backend — Variables de Entorno (Ejemplo)
# ============================================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena TODOS los valores marcados con <REEMPLAZAR>
# 3. NUNCA subas .env a control de versiones (.gitignore ya lo excluye)
# ============================================================================

# ── Base de Datos ─────────────────────────────────────────────────────────────
# Para Docker: usar nombre del servicio "db" en lugar de "localhost"
DATABASE_URL=postgresql://postgres:<REEMPLAZAR_PASSWORD>@db:5432/BD_Calofit

# ── JWT / Seguridad ───────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<REEMPLAZAR_CON_CLAVE_ALEATORIA_64_CHARS>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Groq / OpenRouter (Asistente IA Llama-3 / Gemini) ─────────────────────────
# Obtener Groq key en: https://console.groq.com/keys (empieza con gsk_)
# O bien OpenRouter key en: https://openrouter.ai/ (empieza con sk-or-)
GROQ_API_KEY=<REEMPLAZAR>
GROQ_TIMEOUT_SEC=180
GROQ_MAX_RETRIES=2

# ── USDA FoodData Central ─────────────────────────────────────────────────────
# Obtener en: https://fdc.nal.usda.gov/api-guide.html (gratuito)
USDA_API_KEY=<REEMPLAZAR>

# ── FatSecret API ─────────────────────────────────────────────────────────────
# Obtener en: https://platform.fatsecret.com/api/
FATSECRET_CLIENT_ID=<REEMPLAZAR>
FATSECRET_CLIENT_SECRET=<REEMPLAZAR>
DISABLE_FATSECRET=false

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_API_KEY=<REEMPLAZAR>
FIREBASE_AUTH_DOMAIN=<REEMPLAZAR>
FIREBASE_PROJECT_ID=<REEMPLAZAR>

# ── Cloudinary (Imágenes) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<REEMPLAZAR>
CLOUDINARY_API_KEY=<REEMPLAZAR>
CLOUDINARY_API_SECRET=<REEMPLAZAR>

# ── Email (Brevo/Resend) ──────────────────────────────────────────────────────
BREVO_API_KEY=<REEMPLAZAR>
BREVO_SENDER=<tu_email@dominio.com>
RESEND_API_KEY=<REEMPLAZAR_O_DEJAR_VACIO>

# ── Postgres (para docker-compose) ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<REEMPLAZAR_PASSWORD>
POSTGRES_DB=BD_Calofit
