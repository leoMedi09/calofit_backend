# Copia este archivo a .env y rellena con tus valores reales.
# Nunca subas .env al repositorio.

# Base de datos (Docker: postgresql://postgres:PASSWORD@db:5432/BD_Calofit)
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/BD_Calofit

# Groq (asistente IA) - https://console.groq.com/
GROQ_API_KEY=tu_groq_api_key_aqui
# Opcional: timeout lectura HTTP hacia Groq (segundos)
# GROQ_TIMEOUT_SEC=180
# Opcional: 1 = no llamar a Groq para clasificar modo antes del chat (solo heurística local; ahorra 1 request)
# CALOFIT_DISABLE_CLASIFICAR_MODO_LLM=
# Tests sin Postgres: CALOFIT_DB_FALLBACK_SQLITE=1
# Test manual clasificación real: CALOFIT_LIVE_GROQ_CLASIFICAR=1 (además de GROQ_API_KEY)

# FatSecret Platform API (macros cuando no hay match en CENAN/SQLite local)
# https://platform.fatsecret.com/api/ — OAuth2 client_credentials (scope basic)
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
# Opcional: desactivar aunque existan credenciales (1/true/yes)
# DISABLE_FATSECRET=

# USDA FoodData Central (búsqueda de alimentos) - https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=tu_usda_api_key_aqui

# JWT
SECRET_KEY=tu_clave_secreta_para_jwt

# Opcional: Email (Resend), Firebase, etc.
# RESEND_API_KEY=
# FIREBASE_API_KEY=
